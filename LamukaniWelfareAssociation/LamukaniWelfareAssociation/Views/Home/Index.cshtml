                        <h3 class="donator-name">John Kimani</h3>
                        <p class="donator-program">
                            <a asp-controller="Information" asp-action="SponsorOrphanChild" class="donator-link">
                                Sponsor an orphan child
                            </a>
                        </p>
                        <div class="donator-labels">
                            <span class="donator-label">Donated</span>
                            <span class="donator-cash">1350</span>
                        </div>
                    </div>
                </div>
                <div class="donator-card">
                    <img src="../Img/cooper.jpg" alt="Mary Cooper" class="donator-img" />
                    <div class="donator-details">
                        <h3 class="donator-name">Mary Cooper</h3>
                        <p class="donator-program">
                            <a asp-controller="Information" asp-action="ChildProtection"
                               class="donator-link">
                                Child protection prgram
                            </a>
                        </p>
                        <div class="donator-labels">
                            <span class="donator-label">Donated</span>
                            <span class="donator-cash">8000</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
