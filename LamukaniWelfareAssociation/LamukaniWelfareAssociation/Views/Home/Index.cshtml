<section class="donators">
    <div class="container">
        <div class="donator">
            <h2 class="donator-heading">Our Donators</h2>
            <div class="donator-cards">
                <div class="donator-card">
                    <img src="../Img/wamalwa.jpg"
                         alt="Moses Wamalwa"
                         class="donator-img" />
                    <div class="donator-details">
                        <h3 class="donator-name">Moses Wamalwa</h3>
                        <p class="donator-program">
                            <a asp-controller="Information" asp-action="SupportMilitary"
                               class="donator-link">
                                Support military families
                            </a>
                        </p>
                        <div class="donator-labels">
                            <span class="donator-label">Donated</span>
                            <span class="donator-cash">5400</span>
                        </div>
                    </div>
                </div>
                <div class="donator-card">
                    <img src="../Img/halima.jpg" alt="Halima Juma" class="donator-img" />
                    <div class="donator-details">
                        <h3 class="donator-name">Halima Juma</h3>
                        <p class="donator-program">
                            <a asp-controller="Information" asp-action="FamilySupport" class="donator-link">
                                Family support program
                            </a>
                        </p>
                        <div class="donator-labels">
                            <span class="donator-label">Donated</span>
                            <span class="donator-cash">7800</span>
                        </div>
                    </div>
                </div>
                <div class="donator-card">
                    <img src="../Img/kimani.jpg" alt="John Kimani" class="donator-img" />
